# =====================================================
# Files and directories excluded from Docker build context
# =====================================================

# Dependencies (installed inside the container)
node_modules
npm-debug.log
yarn-debug.log
yarn-error.log

# Next.js build artifacts (built inside the container)
.next
out

# Version control
.git
.gitignore
.gitattributes

# Environment files (mounted/injected at runtime)
.env
.env.*
!.env.example

# Runtime data (mounted as a volume)
data/

# Docker meta files
Dockerfile
docker-compose.yml
.dockerignore

# Nginx configs (used on the host, not in the container)
nginx/

# IDE / editor
.vscode
.idea
*.swp
*.swo
.DS_Store

# Documentation / markdown
*.md
docs/

# Test artifacts
coverage/
.nyc_output

# Misc
*.log
tmp/
