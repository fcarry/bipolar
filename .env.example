# =====================================================
# Bipolar — Medication Tracker
# Environment configuration
# =====================================================
# Copy this file to `.env` and fill in the real values.
# Never commit `.env` to git.
# =====================================================

# --------- Server ---------
NODE_ENV=production
PORT=3000
APP_URL=https://bipolar.tumvp.uy

# --------- Database ---------
# Path INSIDE the container. Do not change unless you also
# update the volume mount in docker-compose.yml.
DATABASE_PATH=/app/data/bipolar.db

# --------- Auth ---------
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET

# Initial admin (seeded on first boot if no admin exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --------- Email (Resend) ---------
# Get your key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Must be a verified sender domain in Resend
MAIL_FROM="Bipolar Alert <alerts@tumvp.uy>"

# --------- Twilio Voice ---------
# Credentials from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Your Twilio virtual number in E.164 format (e.g., +14155238886)
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# --------- Timezone ---------
# Do NOT change. The entire app assumes America/Montevideo.
TZ=America/Montevideo
