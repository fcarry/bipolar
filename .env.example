# =====================================================
# Bipolar — Medication Tracker
# Environment configuration
# =====================================================
# Copy this file to `.env` and fill in the real values.
# Never commit `.env` to git.
# =====================================================

# --------- Server ---------
NODE_ENV=production
PORT=3000
APP_URL=https://bipolar.tumvp.uy

# --------- Database ---------
DATABASE_PATH=/app/data/bipolar.db

# --------- Auth ---------
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET

# Initial admin (seeded on first boot if no admin exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --------- Email (Resend) ---------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
MAIL_FROM="Bipolar Alert <info@tumvp.uy>"

# --------- Twilio Voice ---------
# Account SID (always required)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Authentication — provide ONE of:
#   (A) Auth Token (classic, also enables HMAC webhook signature validation):
TWILIO_AUTH_TOKEN=
#   (B) API Key SID + Secret (modern, recommended; webhook validation falls
#       back to path-based shared secret since API Keys can't sign webhooks):
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

# Your Twilio virtual number in E.164 format
TWILIO_FROM_NUMBER=+10000000000

# Webhook path-based shared secret. Required when no AUTH_TOKEN is set.
# Generate with: openssl rand -hex 24
TWILIO_WEBHOOK_SECRET=

# --------- Timezone ---------
TZ=America/Montevideo
